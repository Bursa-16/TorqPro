From 40f65cc1c47a2bef7e6aeda0711c2faadffb2831 Mon Sep 17 00:00:00 2001
From: TorqPro Dev <ilhan.cekic@torqpro.dev>
Date: Tue, 21 Jul 2026 03:59:13 +0000
Subject: [PATCH 1/3] feat(faz2.4.1c): extend WasherRecord with Faz 2.4.1C
 structured fields

- washer_type, standard_organization, material, surface_finish,
  coating, compatible_bolt_sizes, strength_class, locking_principle,
  operating_temperature_min_c/max_c
- All fields optional/additive; extra=allow preserved from
  LibraryRecordBase
- Verified: existing 189 washer_library.json records still produce
  0 schema violations
---
 backend/library/models.py | 24 +++++++++++++++++++++++-
 1 file changed, 23 insertions(+), 1 deletion(-)

diff --git a/backend/library/models.py b/backend/library/models.py
index 13ddabf..0f8c650 100644
--- a/backend/library/models.py
+++ b/backend/library/models.py
@@ -179,7 +179,17 @@ class NutRecord(LibraryRecordBase):
 
 
 class WasherRecord(LibraryRecordBase):
-    """Washer master record (see ``washer_library.py``)."""
+    """Washer master record (see ``washer_library.py``).
+
+    Faz 2.4.1C additions (all optional, additive -- every Faz 2.4.1
+    plain-washer record that predates these fields keeps validating
+    unchanged, since ``WasherRecord`` keeps ``LibraryRecordBase``'s
+    ``extra="allow"``): structured washer-type/standard-body/material/
+    finish/compatibility/service-limit fields requested by the
+    Faz 2.4.1C brief. Pre-existing fields (``designation``,
+    ``inner_diameter_mm``, ``outer_diameter_mm``, ``thickness_mm``,
+    ``hardness``) are kept as-is, unrenamed.
+    """
 
     designation: str = ""
     inner_diameter_mm: float | None = None
@@ -187,6 +197,18 @@ class WasherRecord(LibraryRecordBase):
     thickness_mm: float | None = None
     hardness: str = ""
 
+    # -- Faz 2.4.1C additions -----------------------------------------
+    washer_type: str = ""
+    standard_organization: str = ""
+    material: str = ""
+    surface_finish: str = ""
+    coating: str = ""
+    compatible_bolt_sizes: List[str] = Field(default_factory=list)
+    strength_class: str = ""
+    locking_principle: str = ""
+    operating_temperature_min_c: float | None = None
+    operating_temperature_max_c: float | None = None
+
 
 #: Faz 2.4.1A thread-record schema version. Deliberately distinct
 #: from ``LibraryRecordBase.version`` / ``LibraryMetadata.version``,
-- 
2.43.0


From d72ab2fc4897f7e73f06341c179ea5a3a1bc80dc Mon Sep 17 00:00:00 2001
From: TorqPro Dev <ilhan.cekic@torqpro.dev>
Date: Tue, 21 Jul 2026 04:05:30 +0000
Subject: [PATCH 2/3] feat(faz2.4.1c): DIN 127 B washer records, search API,
 validators, tests

- tools/generate_faz2_4_1c_washer_records.py: idempotent generator.
  Backfills washer_type/standard_organization/compatible_bolt_sizes
  onto the 189 pre-existing flat-washer records (derived purely from
  each record's own designation/source_standard -- no material/
  coating/strength_class/temperature invented). Appends 34 new
  DIN 127 B (helical spring lock washer, Type B, M2-M100) records
  sourced from Aspen Fasteners' published DIN 127 dimension table.
  Total washer_library.json: 223 records (189 legacy + 34 new).
- backend/library/validator.py: find_non_positive_washer_dimensions,
  find_inner_diameter_not_less_than_outer,
  find_invalid_compatible_bolt_size_format, validate_washer_library
  (reuses find_duplicate_ids / find_duplicate_designation_standard_dimension
  / find_temperature_range_violations / find_missing_source).
- backend/library/population.py: validate_washer_library_records,
  find_washer_by_standard, find_washer_by_size, find_washer_by_material,
  find_washer_for_bolt, find_washer_locking, find_washer_temperature.
- backend/library/facade.py, __init__.py: wire the six washer search
  functions onto LibraryRegistry / package exports.
- tests/test_faz2_4_1c_washer_engineering_database.py: 35 tests
  (schema, backfill correctness, no-invented-data assertions,
  duplicate detection, dimension/format validators, all six search
  functions, checksum integrity, generator idempotency).

Quality gate: pytest 473/473, flake8 --max-line-length=100 clean on
all changed files, black --check clean on all changed/new lines
(pre-existing non-black-formatted lines in facade.py/population.py
left untouched, out of scope).
---
 backend/library/__init__.py                   |   12 +
 backend/library/data/washer_library.json      | 2824 +++++++++++++++--
 backend/library/facade.py                     |   43 +
 backend/library/population.py                 |  105 +
